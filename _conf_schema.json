  "persona_1": {
    "description": "人格1 TTS配置",
    "type": "object",
    "items": {
      "select_persona": {
        "type": "string",
        "description": "人格",
        "default": "default",
        "_special": "select_persona"
      },
      "provider_id": {
        "type": "string",
        "description": "TTS 提供商 ID",
        "hint": "填写在上方「TTS 提供商」中配置的提供商 ID（如 siliconflow、minimax、mimo）。",
        "obvious_hint": true
      },
      "inject_prompt": {
        "type": "bool",
        "description": "注入提示词",
        "hint": "开启后会在系统提示词中注入语音风格控制说明。默认关闭。",
        "default": false
      },
      "speed": {
        "type": "float",
        "description": "语速覆盖",
        "hint": "覆盖提供商默认语速。1.0 表示使用提供商默认。",
        "default": 1.0
      },
      "prob": {
        "type": "float",
        "description": "语音输出概率",
        "hint": "每次回复生成语音的概率，0.0~1.0。1.0 表示始终生成。",
        "default": 1.0
      },
      "text_voice_output": {
        "type": "string",
        "description": "文字与语音同时输出",
        "hint": "开启后同时发送文字和语音；关闭后仅发送语音。留空使用默认。",
        "options": [
          "",
          "true",
          "false"
        ],
        "default": ""
      }
    }
  },
