  "personas": {
    "description": "人格 TTS 配置",
    "hint": "为每个人格配置 TTS 提供商和音色。先在上方添加提供商，再在此引用提供商 ID。",
    "type": "template_list",
    "templates": {
      "persona": {
        "name": "人格配置",
        "items": {
          "select_persona": {
            "type": "string",
            "description": "人格",
            "default": "default",
            "_special": "select_persona"
          },
          "provider_id": {
            "type": "string",
            "description": "提供商 ID",
            "hint": "填写在提供商池中配置的 ID。"
          },
          "voice": {
            "type": "string",
            "description": "音色覆盖",
            "hint": "覆盖提供商默认音色。留空使用提供商默认值。"
          },
          "default_style": {
            "type": "string",
            "description": "默认风格",
            "hint": "无风格标签时使用的默认风格。留空表示不添加风格。",
            "default": ""
          },
          "speed": {
            "type": "float",
            "description": "语速覆盖",
            "hint": "覆盖提供商默认语速。0 表示使用提供商默认值。",
            "default": 0
          }
        }
      }
    }
